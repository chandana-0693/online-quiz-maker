{
  "name": "online-quiz-maker-backend",
  "version": "1.0.0",
  "description": "Full-stack backend for QuizVerse Online Quiz Maker using Node.js, Express, and Prisma SQLite",
  "main": "server.js",
  "scripts": {
    "start": "node node_modules/prisma/build/index.js migrate deploy && node prisma/seed.js && node server.js",
    "dev": "nodemon server.js",
    "build": "node node_modules/prisma/build/index.js generate",
    "postinstall": "node node_modules/prisma/build/index.js generate",
    "db:migrate": "node node_modules/prisma/build/index.js migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "node node_modules/prisma/build/index.js studio"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
